# ──────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=salescrm
POSTGRES_PASSWORD=salescrm
POSTGRES_DB=salescrm

# 或者直接提供完整连接串（优先级高于上面的分项配置）：
# DATABASE_URL=postgresql://salescrm:salescrm@localhost:5432/salescrm

# ──────────────────────────────────────────────
# App / 内部服务
# ──────────────────────────────────────────────

# 应用 ↔ pi-agent sidecar 内部鉴权（生产环境务必修改！）
PI_INTERNAL_SECRET=change-me-in-production

# pi-agent sidecar 地址（docker compose 默认值，通常无需修改）
# PI_AGENT_SERVICE_URL=http://pi-agent:8001

# docker compose 对外端口（默认 8000）
# APP_PORT=8000

# ──────────────────────────────────────────────
# 可选搜索渠道
# ──────────────────────────────────────────────

# Bright Data Google SERP（可选，不填则跳过网络搜索）
# BRIGHTDATA_API_KEY=
# BRIGHTDATA_SERP_ZONE=serp_api1

# Legacy SQLite 一次性迁移（可选）
# SQLITE_PATH=data/salescrm.db

# ──────────────────────────────────────────────
# 外部 Agent / Reasonix
# ──────────────────────────────────────────────
# Reasonix 通过 SALESCRM_URL + SALESCRM_TOKEN 访问本应用，
# 这两个变量在 Reasonix 侧按 agent 配置，不属于 compose 变量，
# 此处无需设置。详见 integrations/reasonix/README.md。
