# PostgreSQL connection (used by docker-compose by default)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=salescrm
POSTGRES_PASSWORD=salescrm
POSTGRES_DB=salescrm

# Or set a full URL instead:
# DATABASE_URL=postgresql://salescrm:salescrm@localhost:5432/salescrm

# Legacy SQLite migration (optional one-time):
# SQLITE_PATH=data/salescrm.db

# App port when using docker compose
# APP_PORT=8000
