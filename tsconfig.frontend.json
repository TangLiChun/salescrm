{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "rootDir": "frontend/src",
    "outDir": "app/static",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": false,
    "noImplicitAny": false,
    "checkJs": false,
    "allowJs": false,
    "skipLibCheck": true,
    "sourceMap": false,
    "declaration": false,
    "removeComments": false,
    "noEmitOnError": true
  },
  "include": ["frontend/src/**/*.ts", "frontend/src/**/*.d.ts"]
}
