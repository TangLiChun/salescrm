{
  "name": "salescrm-pi-agent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "npm run build && npm run test:types && node --test \"test/*.test.mjs\"",
    "test:types": "tsc --noEmit --target ES2022 --module NodeNext --moduleResolution NodeNext --strict --skipLibCheck test/agentEvents.typecheck.ts",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test:unit": "node --test \"test/*.test.mjs\""
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "hono": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
